{
  "appId": "com.flowclassroom.student",
  "productName": "FlowClassroom Student",
  "directories": {
    "output": "dist/student",
    "buildResources": "buildResources"
  },
  "files": [
    "electron/main.js",
    "electron/preload.js",
    "build-student/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "electron/main.js",
    "buildTarget": "student"
  },
  "win": {
    "target": "portable",
    "icon": "buildResources/icon.ico"
  },
  "portable": {
    "artifactName": "FlowClassroom-Student.exe"
  }
}
